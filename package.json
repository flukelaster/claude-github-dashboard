{
  "name": "claude-github-dashboard",
  "private": true,
  "version": "0.1.0",
  "description": "Cross-reference Claude Code usage with GitHub output — local-only dashboard",
  "scripts": {
    "dev": "concurrently -n server,web -c cyan,magenta \"pnpm --filter @cgd/server dev\" \"pnpm --filter @cgd/web dev\"",
    "build": "pnpm --filter @cgd/shared build && pnpm --filter @cgd/server build && pnpm --filter @cgd/web build",
    "start": "node apps/server/dist/apps/server/src/index.js",
    "db:generate": "pnpm --filter @cgd/server db:generate",
    "db:migrate": "pnpm --filter @cgd/server db:migrate",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@10.29.2",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "keytar"
    ]
  }
}
